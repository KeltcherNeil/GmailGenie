# Copy to backend/.env for local dev. In production these are set on Cloud Run
# (ANTHROPIC_API_KEY via Secret Manager). See backend/DEPLOY.md.

# Required — server-side Claude key (never ships in the extension).
ANTHROPIC_API_KEY=your_key_here

# Production auth/abuse controls. Left unset in local dev = checks disabled.
# ALLOWED_ORIGINS: comma-separated extension origins allowed to call /extract-event.
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID
# GOOGLE_CLIENT_ID: the extension's OAuth client id. When set, callers must present
# a Google token minted for this client (per-user auth). Must match manifest.json.
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Local dev only.
FLASK_ENV=development
PORT=5001
