{
  "manifest_version": 3,
  "name": "GmailGenie",
  "version": "1.5.0",
  "description": "Detects scheduling info in your Gmail and adds it to Google Calendar in one click.",
  "key": "",
  "permissions": [
    "storage",
    "activeTab",
    "identity"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://gmailgenie-485353812643.us-central1.run.app/*",
    "https://www.googleapis.com/calendar/v3/*"
  ],
  "oauth2": {
    "client_id": "485353812643-d4sfmug4qjl03sk13dljbhkq0sojk4vf.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "https://www.googleapis.com/auth/calendar.events"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "GmailGenie",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
